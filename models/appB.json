{
  "appB" : [
    {
      "type" : "set_value",
      "args" : {
         "colorValue1" : "00FF00"
      },
      "child" : {
      "type": "preferred_size",
      "args": {
        "preferredSize": "${sizeValue}"
      },
      "child": {
        "type": "gesture_detector",
        "args": {
          "onLongPress": "${colorPicker()}"
        },
        "child": {
          "type": "app_bar",
          "args": {
            "title": {
              "type": "text",
              "args": {
                "text": "BottomNavigationBarModel"
              }
            },
            "backgroundColor" : "${colorValue1}"
          }
        }
      }
    }},
    {
      "type" : "set_value",
      "args" : {
        "colorValue1" : "FF0000"
      },
      "child" : {
      "type": "preferred_size",
      "args": {
        "preferredSize": "${sizeValue}"
      },
      "child": {
        "type": "gesture_detector",
        "args": {
          "onLongPress": "${colorPicker()}"
        },
        "child": {
          "type": "app_bar",
          "args": {
            "backgroundColor": "${colorValue1}",
            "title": {
              "type": "text",
              "args": {
                "text": "BottomNavigationBarModel"
              }
            }
          }
        }
      }
    }}
  ]
}
