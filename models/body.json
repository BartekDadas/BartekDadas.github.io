{
  "bb" : [
    {
     "type": "set_widget",
      "args": {
        "customFirstText": {
          "type": "text",
          "args": {
            "text": "1",
            "style": {
              "fontSize": 64
            }
          }
        },
        "customSecondText": {
          "type": "text",
          "args": {
            "text": "2",
            "style": {
              "fontSize": 64
            }
          }
        }
      },
      "child": {
        "type": "center",
        "child": {
          "type": "animated_switcher",
          "args": {
            "child": "${customFirstText}",
            "duration": 1000
          }
        }
      }
    },
    {
      "type": "center",
      "child": {
        "args": {
          "text": "Files are being prepared"}, "type": "text"}
    }
  ]
}
